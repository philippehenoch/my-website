---
import { Image } from 'astro:assets';
import photo from '../assets/philippe_henoch.jpeg';
import '../styles/global.css';

const description = "Philippe Henoch — Technical Solutions Manager with 6+ years of experience supporting enterprise SaaS customers across Europe and APAC.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content="Philippe Henoch" />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://philippehenoch.fr/" />
		<meta property="og:image" content="https://philippehenoch.fr/images/philippe_henoch.jpeg" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Philippe Henoch" />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://philippehenoch.fr/images/philippe_henoch.jpeg" />
		<link rel="canonical" href="https://philippehenoch.fr/" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="preload" href="/fonts/Calibre/Calibre-Regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/Calibre/Calibre-Semibold.woff2" as="font" type="font/woff2" crossorigin />
		<title>Philippe Henoch</title>
		<script is:inline type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Philippe Henoch",
			"jobTitle": "Technical Solutions Manager",
			"url": "https://philippehenoch.fr",
			"sameAs": ["https://www.linkedin.com/in/philippehenoch/"],
			"image": "https://philippehenoch.fr/images/philippe_henoch.jpeg",
			"description": "Technical Solutions Manager with 6+ years of experience supporting enterprise SaaS customers across Europe and APAC."
		}
		</script>
	</head>
	<body class="flex flex-col min-h-screen">
		<main
			class="p-6 max-w-5xl m-auto flex-1 flex justify-center items-center gap-4 flex-wrap md:flex-nowrap"
		>
			<div>
				<p class="font-text text-text text-heading m-0">Hi, my name is</p><h1
					class="font-title text-title text-heading font-semibold m-0"
				>
					Philippe Henoch.
				</h1><p class="font-title font-normal text-xl mt-4 mb-0">
					Technical solutions manager with 6+ years of experience
					supporting enterprise SaaS customers across Europe and APAC.
					Expertise in technical consulting, pre-sales, JavaScript
					development, API integrations, and customer enablement.
					Supported 600+ customers, including Cartier, Crypto.com,
					Bandai, Disneyland Paris, and Samsonite, and built
					AI-powered tools that improved efficiency and knowledge
					sharing across teams.
				</p><div class="flex gap-3 mt-6">
					<a
						href="https://www.linkedin.com/in/philippehenoch/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-heading text-heading font-text text-sm no-underline hover:bg-heading hover:text-background transition-colors"
					>
						<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M7.501 9H3.5a.5.5 0 0 0-.5.499V21.5a.5.5 0 0 0 .499.5H7.5a.5.5 0 0 0 .5-.499V9.5a.5.5 0 0 0-.499-.5zM7 21H4V10h3v11zM18 9a4.93 4.93 0 0 0-3 1.019V9.5a.5.5 0 0 0-.499-.5H10.5a.5.5 0 0 0-.5.499V21.5a.5.5 0 0 0 .499.5H14.5a.5.5 0 0 0 .5-.499V16a1.5 1.5 0 1 1 3 0v5.5a.5.5 0 0 0 .499.5H22.5a.5.5 0 0 0 .5-.499V14a5.006 5.006 0 0 0-5-5zm4 12h-3v-5a2.5 2.5 0 1 0-5 0v5h-3V10h3v1.203a.5.5 0 0 0 .335.472c.2.072.424.008.556-.159a3.982 3.982 0 0 1 7.11 2.485v7zM5.868 2.002A2.73 2.73 0 0 0 5.515 2a2.74 2.74 0 0 0-2.919 2.546l-.006.182a2.71 2.71 0 0 0 2.686 2.733l.183-.005h.028a2.734 2.734 0 1 0 .381-5.455zM5.833 6.46c-.115.011-.232.01-.347-.003h-.028a1.736 1.736 0 0 1-.266-3.462A1.74 1.74 0 0 1 5.515 3a1.74 1.74 0 0 1 1.889 1.57 1.74 1.74 0 0 1-1.571 1.89z"/></svg>
						LinkedIn
					</a>
					<a
						href="/philippe-henoch-resume.pdf"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-heading text-background font-text text-sm no-underline hover:opacity-90 transition-opacity"
					>
						<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 16l-5-5 1.4-1.4 2.6 2.6V4h2v8.2l2.6-2.6L17 11l-5 5zm-7 4v-2h14v2H5z"/></svg>
						Resume
					</a>
				</div>
			</div><Image
				src={photo}
				alt="Philippe Henoch"
				width={324}
				height={324}
				densities={[1, 2]}
				loading="eager"
				fetchpriority="high"
				class="aspect-square rounded-2xl flex-none"
			/>
		</main>
		<footer class="p-6 text-center">
			<a href="/mentions-legales" class="font-text text-text text-heading opacity-75 hover:opacity-100 transition-opacity no-underline">
				Mentions légales
			</a>
		</footer>
	</body>
</html>
